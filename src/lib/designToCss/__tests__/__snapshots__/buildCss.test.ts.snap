exports[`buildCssForNodes > generates a CSS block for a rect with a gradient fill and drop shadow 1`] = `
"/* Card */
.card {
  box-sizing: border-box;
  width: 200px;
  height: 100px;
  background-image: linear-gradient(180deg, #ff0000 0%, #0000ff 100%);
  background-size: auto;
  background-position: 0% 0%;
  background-repeat: repeat;
  border-radius: 12px;
  box-shadow: 0px 4px 8px 0px #00000040;
}"
`;

exports[`buildCssForNodes > generates flexbox CSS for an auto-layout frame 1`] = `
"/* Row */
.row {
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  gap: 12px;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  width: 300px;
  height: 60px;
  background-color: #ffffff;
}"
`;
